+
+func assertOwner(info os.FileInfo, owner string) error {
+	sys, ok := info.Sys().(*syscall.Stat_t)
+	if !ok {
+		return nil
+	}
+	u, err := user.Lookup(owner)
+	if err != nil {
+		return nil
+	}
+	expectedUID := u.Uid
+	if fmt.Sprint(sys.Uid) != expectedUID {
+		return fmt.Errorf("uid %d != %s", sys.Uid, expectedUID)
+	}
+	return nil
+}
+
+func assertFileHash(path, expected string) error {
+	data, err := os.ReadFile(path)
+	if err != nil {
+		return err
+	}
+	sum := sha256.Sum256(data)
+	hash := hex.EncodeToString(sum[:])
+	if hash != expected {
+		return fmt.Errorf("sha256 %s != %s", hash, expected)
+	}
+	return nil
+}
