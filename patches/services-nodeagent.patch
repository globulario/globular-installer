 func fileModeMatches(actual os.FileMode, expected string) bool {
 	trim := strings.TrimPrefix(expected, "0")
 	parsed, err := strconv.ParseUint(trim, 8, 32)
 	if err != nil {
 		return true
 	}
 	return actual.Perm() == os.FileMode(parsed)
 }
