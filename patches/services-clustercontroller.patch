@@
+package reconcile
+
+import (
+	"encoding/json"
+	"fmt"
+	"time"
+
+	"github.com/globulario/services/golang/plan/planpb"
+	"github.com/google/uuid"
+	"google.golang.org/protobuf/types/known/structpb"
+)
+
+// ClusterDesiredState represents the effective network/domain configuration a node should have.
+type ClusterDesiredState struct {
+	ClusterID  string
+	Domain     string
+	Protocol   string
+	PortHTTP   uint32
+	PortHTTPS  uint32
+	ACME       bool
+	AdminEmail string
+}
+
+// NodeObservedState is a placeholder for future drift detection data.
+type NodeObservedState struct{}
+
+// ServiceDesiredVersion captures a target version for a service.
+type ServiceDesiredVersion struct {
+	Name    string
+	Unit    string
+	Version string
+}
+
+// BuildNetworkTransitionPlan renders a plan that writes network config and restarts edge services.
+func BuildNetworkTransitionPlan(nodeID string, desired ClusterDesiredState, _ NodeObservedState) (*planpb.NodePlan, error) {
+	if nodeID == "" {
+		return nil, fmt.Errorf("nodeID is required")
+	}
+	planID := uuid.NewString()
+	payload := map[string]any{
+		"cluster_domain":    desired.Domain,
+		"protocol":          desired.Protocol,
+		"port_http":         desired.PortHTTP,
+		"port_https":        desired.PortHTTPS,
+		"alternate_domains": []string{},
+		"acme_enabled":      desired.ACME,
+		"admin_email":       desired.AdminEmail,
+	}
+	content, err := json.MarshalIndent(payload, "", "  ")
+	if err != nil {
+		return nil, err
+	}
+
+	steps := []*planpb.PlanStep{
+		step("file.write_atomic", map[string]any{
+			"path":    "/var/lib/globular/services/network.json",
+			"content": string(content),
+		}),
+		step("service.restart", map[string]any{"unit": "globular-gateway.service"}),
+		step("service.restart", map[string]any{"unit": "globular-xds.service"}),
+		step("service.restart", map[string]any{"unit": "envoy.service"}),
+	}
+
+	policy := &planpb.PlanPolicy{
+		MaxRetries:       3,
+		RetryBackoffMs:   2_000,
+		FailureMode:      planpb.FailureMode_FAILURE_MODE_ABORT,
+		MaxParallelSteps: 1,
+	}
+
+	return &planpb.NodePlan{
+		ApiVersion:    "globular.io/plan/v1",
+		Kind:          "NodePlan",
+		ClusterId:     desired.ClusterID,
+		NodeId:        nodeID,
+		PlanId:        planID,
+		Generation:    uint64(time.Now().UnixNano()),
+		CreatedUnixMs: uint64(time.Now().UnixMilli()),
+		Reason:        "update-network",
+		Locks: []string{
+			"network",
+			"tls",
+			"service:gateway",
+			"service:xds",
+			"service:envoy",
+		},
+		Policy: policy,
+		Spec: &planpb.PlanSpec{
+			Steps: steps,
+			Desired: &planpb.DesiredState{
+				Services: []*planpb.DesiredService{
+					{Name: "gateway", Unit: "globular-gateway.service"},
+					{Name: "xds", Unit: "globular-xds.service"},
+					{Name: "envoy", Unit: "envoy.service"},
+				},
+				Files: []*planpb.DesiredFile{
+					{Path: "/var/lib/globular/services/network.json"},
+				},
+			},
+			SuccessProbes: []*planpb.Probe{
+				{Type: "probe.http", Args: toStruct(map[string]any{"url": fmt.Sprintf("http://%s", desired.Domain), "timeout_ms": 2000})},
+			},
+		},
+	}, nil
+}
+
+// BuildServiceUpgradePlan produces a plan that installs a target version and writes a version marker.
+func BuildServiceUpgradePlan(nodeID string, svc ServiceDesiredVersion, _ NodeObservedState) (*planpb.NodePlan, error) {
+	if nodeID == "" {
+		return nil, fmt.Errorf("nodeID is required")
+	}
+	if svc.Name == "" {
+		return nil, fmt.Errorf("service name is required")
+	}
+	planID := uuid.NewString()
+	unit := svc.Unit
+	if unit == "" {
+		unit = fmt.Sprintf("globular-%s.service", svc.Name)
+	}
+	versionFile := fmt.Sprintf("/var/lib/globular/services/%s/version", svc.Name)
+	steps := []*planpb.PlanStep{
+		step("service.stop", map[string]any{"unit": unit}),
+		step("service.start", map[string]any{"unit": unit}),
+		step("file.write_atomic", map[string]any{"path": versionFile, "content": svc.Version + "\n"}),
+		step("service.restart", map[string]any{"unit": unit}),
+	}
+	return &planpb.NodePlan{
+		ApiVersion:    "globular.io/plan/v1",
+		Kind:          "NodePlan",
+		NodeId:        nodeID,
+		PlanId:        planID,
+		Generation:    uint64(time.Now().UnixNano()),
+		CreatedUnixMs: uint64(time.Now().UnixMilli()),
+		Reason:        "upgrade-service",
+		Locks:         []string{"service:" + svc.Name},
+		Policy: &planpb.PlanPolicy{
+			MaxRetries:     3,
+			RetryBackoffMs: 2000,
+			FailureMode:    planpb.FailureMode_FAILURE_MODE_ROLLBACK,
+		},
+		Spec: &planpb.PlanSpec{
+			Steps: steps,
+			Desired: &planpb.DesiredState{
+				Services: []*planpb.DesiredService{
+					{Name: svc.Name, Unit: unit, Version: svc.Version},
+				},
+				Files: []*planpb.DesiredFile{
+					{Path: versionFile},
+				},
+			},
+			SuccessProbes: []*planpb.Probe{
+				{Type: "probe.http", Args: toStruct(map[string]any{"url": "http://localhost:8080/healthz", "timeout_ms": 2000})},
+			},
+		},
+	}, nil
+}
+
+func step(action string, args map[string]any) *planpb.PlanStep {
+	return &planpb.PlanStep{
+		Id:     action,
+		Action: action,
+		Args:   toStruct(args),
+	}
+}
+
+func toStruct(m map[string]any) *structpb.Struct {
+	s, _ := structpb.NewStruct(m)
+	return s
+}
