+
+func (srv *server) reconcileNetworkPlans(ctx context.Context) {
+	if srv.planStore == nil || srv.state.ClusterNetworkSpec == nil {
+		return
+	}
+	desired := reconcile.ClusterDesiredState{
+		ClusterID:  srv.state.ClusterId,
+		Domain:     srv.state.ClusterNetworkSpec.GetClusterDomain(),
+		Protocol:   srv.state.ClusterNetworkSpec.GetProtocol(),
+		PortHTTP:   srv.state.ClusterNetworkSpec.GetPortHttp(),
+		PortHTTPS:  srv.state.ClusterNetworkSpec.GetPortHttps(),
+		ACME:       srv.state.ClusterNetworkSpec.GetAcmeEnabled(),
+		AdminEmail: srv.state.ClusterNetworkSpec.GetAdminEmail(),
+	}
+	for nodeID := range srv.state.Nodes {
+		plan, err := reconcile.BuildNetworkTransitionPlan(nodeID, desired, reconcile.NodeObservedState{})
+		if err != nil || plan == nil {
+			continue
+		}
+		if plan.GetGeneration() == 0 {
+			plan.Generation = srv.state.NetworkingGeneration
+		}
+		_ = srv.planStore.PutCurrentPlan(ctx, nodeID, plan)
+	}
+}
