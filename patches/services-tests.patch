@@
+package planexec
+
+import (
+	"context"
+	"os"
+	"path/filepath"
+	"testing"
+
+	"github.com/globulario/services/golang/nodeagent/nodeagent_server/internal/actions"
+	"github.com/globulario/services/golang/plan/planpb"
+	"google.golang.org/protobuf/types/known/structpb"
+)
+
+type okProbe struct{}
+
+func (okProbe) Name() string { return "test.ok" }
+func (okProbe) Validate(*structpb.Struct) error { return nil }
+func (okProbe) Apply(context.Context, *structpb.Struct) (string, error) { return "ok", nil }
+
+func TestReconcileQuickSuccess(t *testing.T) {
+	actions.Register(okProbe{})
+	r := NewRunner("node-1", func(context.Context, *planpb.NodePlanStatus) {})
+	plan := &planpb.NodePlan{
+		NodeId: "node-1",
+		PlanId: "p1",
+		Spec: &planpb.PlanSpec{
+			SuccessProbes: []*planpb.Probe{
+				{Type: "test.ok"},
+			},
+		},
+	}
+	status, err := r.ReconcilePlan(context.Background(), plan, nil)
+	if err != nil {
+		t.Fatalf("reconcile error: %v", err)
+	}
+	if status.GetState() != planpb.PlanState_PLAN_SUCCEEDED {
+		t.Fatalf("expected PLAN_SUCCEEDED, got %v", status.GetState())
+	}
+}
+
+func TestDesiredServiceVersionCheck(t *testing.T) {
+	tmp := t.TempDir()
+	restoreRoot := overrideVersionMarkerRoot(tmp)
+	defer restoreRoot()
+	restoreActive := overrideIsServiceActive(func(context.Context, string) (bool, error) { return true, nil })
+	defer restoreActive()
+
+	serviceDir := filepath.Join(tmp, "globular-gateway")
+	if err := os.MkdirAll(serviceDir, 0o755); err != nil {
+		t.Fatalf("mkdir: %v", err)
+	}
+	if err := os.WriteFile(filepath.Join(serviceDir, "version"), []byte("1.2.3\n"), 0o644); err != nil {
+		t.Fatalf("write version: %v", err)
+	}
+
+	services := []*planpb.DesiredService{
+		{Name: "gateway", Unit: "globular-gateway.service", Version: "1.2.3"},
+	}
+	if err := checkDesiredServices(context.Background(), services); err != nil {
+		t.Fatalf("expected version match, got error: %v", err)
+	}
+
+	services[0].Version = "9.9.9"
+	if err := checkDesiredServices(context.Background(), services); err == nil {
+		t.Fatalf("expected version mismatch error")
+	}
+}
+
+func overrideVersionMarkerRoot(root string) func() {
+	old := versionMarkerRoot
+	versionMarkerRoot = root
+	return func() { versionMarkerRoot = old }
+}
+
+func overrideIsServiceActive(fn func(context.Context, string) (bool, error)) func() {
+	old := isServiceActive
+	isServiceActive = fn
+	return func() { isServiceActive = old }
+}
