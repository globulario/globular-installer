diff --git a/services/golang/nodeagent/nodeagent_server/server_applyplanv1_test.go b/services/golang/nodeagent/nodeagent_server/server_applyplanv1_test.go
index 0000000..0000000 100644
--- a/services/golang/nodeagent/nodeagent_server/server_applyplanv1_test.go
+++ b/services/golang/nodeagent/nodeagent_server/server_applyplanv1_test.go
@@
+package main
+
+import (
+	"context"
+	"testing"
+
+	nodeagentpb "github.com/globulario/services/golang/nodeagent/nodeagentpb"
+	"github.com/globulario/services/golang/plan/planpb"
+)
+
+type fakePlanStore struct {
+	plan    *planpb.NodePlan
+	status  *planpb.NodePlanStatus
+	history []*planpb.NodePlan
+}
+
+func (f *fakePlanStore) PutCurrentPlan(_ context.Context, _ string, plan *planpb.NodePlan) error {
+	f.plan = plan
+	return nil
+}
+func (f *fakePlanStore) GetCurrentPlan(_ context.Context, _ string) (*planpb.NodePlan, error) {
+	return f.plan, nil
+}
+func (f *fakePlanStore) PutStatus(_ context.Context, _ string, status *planpb.NodePlanStatus) error {
+	f.status = status
+	return nil
+}
+func (f *fakePlanStore) GetStatus(_ context.Context, _ string) (*planpb.NodePlanStatus, error) {
+	return f.status, nil
+}
+func (f *fakePlanStore) AppendHistory(_ context.Context, _ string, plan *planpb.NodePlan) error {
+	f.history = append(f.history, plan)
+	return nil
+}
+
+func TestApplyPlanV1ReturnsCorrelation(t *testing.T) {
+	ps := &fakePlanStore{}
+	srv := &NodeAgentServer{
+		planStore: ps,
+		nodeID:    "node-1",
+		state:     newNodeAgentState(),
+	}
+	req := &nodeagentpb.ApplyPlanV1Request{
+		Plan: &planpb.NodePlan{
+			NodeId: "node-1",
+		},
+	}
+	resp, err := srv.ApplyPlanV1(context.Background(), req)
+	if err != nil {
+		t.Fatalf("ApplyPlanV1 error: %v", err)
+	}
+	if resp.GetOperationId() == "" {
+		t.Fatalf("expected non-empty operation_id")
+	}
+	if resp.GetPlanId() == "" {
+		t.Fatalf("expected plan_id to be set")
+	}
+	if resp.GetPlanGeneration() == 0 {
+		t.Fatalf("expected plan_generation to be set")
+	}
+	if ps.plan == nil {
+		t.Fatalf("expected plan persisted")
+	}
+	if ps.plan.GetPlanId() != resp.GetPlanId() {
+		t.Fatalf("plan_id mismatch: plan=%s resp=%s", ps.plan.GetPlanId(), resp.GetPlanId())
+	}
+}
diff --git a/services/golang/nodeagent/nodeagent_server/internal/planexec/planexec_test.go b/services/golang/nodeagent/nodeagent_server/internal/planexec/planexec_test.go
index 0000000..0000000 100644
--- a/services/golang/nodeagent/nodeagent_server/internal/planexec/planexec_test.go
